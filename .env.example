# ──────────────────────────────────────────────
# GrowEasy CSV Importer — Environment Variables
# Copy to .env and fill in values
# ──────────────────────────────────────────────

# Application
NODE_ENV=development
APP_NAME=groweasy-csv-importer
LOG_LEVEL=info

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Backend
PORT=4000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
# Production: comma-separated origins, wildcards supported
# Example: https://groweasy.vercel.app,*.vercel.app

# LLM Provider — openrouter (free Qwen) | mock | anthropic | openai | gemini
LLM_PROVIDER=openrouter

# ── OpenRouter + free Qwen (recommended — no paid API balance needed) ─────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen-2.5-7b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=GrowEasy Import

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Upload limits
MAX_UPLOAD_SIZE_MB=10

# AI Extraction
PROMPT_VERSION=v2
# Options: v1 (legacy), v2 (production), experimental (full few-shot)
LLM_CONTEXT_WINDOW=200000
LLM_TARGET_CONTEXT_RATIO=0.7
LLM_MAX_RETRIES=3
LLM_REQUEST_TIMEOUT_MS=120000
LLM_MAX_CONCURRENT_BATCHES=3
IMPORT_JOB_TTL_MS=3600000
